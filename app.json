{
  "expo": {
    "name": "PropTech Club",
    "slug": "proptech-club",
    "version": "1.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "proptechclub",
    "icon": "./assets/icon-contained.png",
    "splash": {
      "image": "./assets/icon-contained.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B196A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pk.landtrack.proptech.club",
      "buildNumber": "6"
    },
    "android": {
      "package": "pk.landtrack.proptech.club",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-contained.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      "expo-image",
      [
        "expo-image-picker",
        {
          "cameraPermission": "PropTech Club uses your camera so you can take and upload a profile photo within the app.",
          "photosPermission": "PropTech Club uses your photo library so you can select and upload a profile photo within the app."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93908231-c182-44fa-ac79-3870283ca446"
      }
    },
    "owner": "atifbackup61"
  }
}
